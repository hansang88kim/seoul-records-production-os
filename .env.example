# ─── AI APIs ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# ─── Canva ────────────────────────────────────────────────────────────────────
CANVA_MCP_TOKEN=

# ─── YouTube ──────────────────────────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ─── Suno Provider ────────────────────────────────────────────────────────────
# Provider selection: mock | manual_import | local_unofficial | playwright_web
COMPOSER_PROVIDER=mock
SUNO_LOCAL_API_BASE_URL=http://localhost:3000
SUNO_COOKIE=
SUNO_SESSION_PATH=
SUNO_DOWNLOAD_FORMAT=wav
SUNO_LOCAL_TIMEOUT=30

# ─── Provider Policy ─────────────────────────────────────────────────────────
ALLOW_MP3_FOR_DISTRIBUTION=false
ALLOW_THIRD_PARTY_SUNO=false

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
